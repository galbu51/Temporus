{
  "manifest_version":3,

  "name":"Temporus",

  "version":"1.0",

  "description":"Extensão para personalização visual e acessibilidade em páginas da web.",


  "permissions":[
    "storage",
    "activeTab",
    "scripting"
  ],


  "host_permissions":[
    "<all_urls>"
  ],


  "action":{
    "default_popup":"popup.html"
  },


  "content_scripts":[

    {

      "matches":[
        "<all_urls>"
      ],

      "js":[
        "content.js"
      ]

    }

  ]

}